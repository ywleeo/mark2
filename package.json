    "@tiptap/starter-kit": "^3.13.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.35",
    "lowlight": "^3.3.0",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.1.0",
