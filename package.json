{
  "name": "mark2-tauri",
  "productName": "Mark2",
  "version": "1.6.27",
  "type": "module",
  "description": "一个基于 Tauri 的 Markdown 阅读器",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "tauri:build": "tauri build",
    "tauri:run": "open src-tauri/target/release/bundle/macos/Mark2.app",
    "release:github": "bash ./scripts/release-github.sh",
    "release:mac": "bash ./scripts/release-github.sh --platform mac",
    "release:win": "bash ./scripts/release-github.sh --platform win",
    "release:mas": "bash ./scripts/release-mas.sh"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.1",
