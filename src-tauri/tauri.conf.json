{
  "productName": "Mark2",
  "version": "1.6.24",
  "identifier": "cc.altron.mark2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "scope": [
          "**"
        ]
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "files": {
        "Info.plist": "macos/Info.plist"
      },
      "entitlements": "macos/Mark2.entitlements"
    },
    "category": "Productivity",
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "mimeType": "text/markdown",
        "description": "Markdown Document",
        "role": "Editor"
      }
    ]
  }
}
