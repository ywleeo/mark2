{
  "productName": "Mark2",
  "version": "1.6.25",
  "identifier": "cc.altron.mark2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "scope": [
          "**"
        ]
      }
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://mark2app.com/api/app/version?platform=mac"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCMjBDMjg3QUJDMjE0N0UKUldSK0ZNS3JoOElnMit4dVdGTmo0Uk45ZGgxUTJMRlBqYTdKRXBLcDNaNVpLTVRxK210NEt4a2YK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "files": {
        "Info.plist": "macos/Info.plist"
      },
      "entitlements": "macos/Mark2.entitlements"
    },
    "category": "Productivity",
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "mimeType": "text/markdown",
        "description": "Markdown Document",
        "role": "Editor"
      }
    ]
  }
}
