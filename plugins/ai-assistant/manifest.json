{
  "id": "ai-assistant",
  "name": "AI 写作助手",
  "version": "1.0.0",
  "description": "基于 LLM 的智能写作助手，支持流式对话",
  "author": "Mark2 Team",

  "frontend": {
    "entry": "./frontend/index.js",
    "enabled": true
  },

  "menu": {
    "toggle": {
      "label": "Toggle AI 写作助手",
      "accelerator": "CmdOrCtrl+Shift+A"
    },
    "settings": {
      "label": "AI 写作助手 Settings...",
      "accelerator": "CmdOrCtrl+Shift+,"
    }
  },

  "permissions": [
    "network:request"
  ]
}
